            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">
            <TextView android:id="@+id/cell_7" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_8" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_9" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_10" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_11" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_12" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_13" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">
            <TextView android:id="@+id/cell_14" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_15" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
