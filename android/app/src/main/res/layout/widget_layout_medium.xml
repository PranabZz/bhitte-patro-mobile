            <TextView android:id="@+id/cell_20" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">
            <TextView android:id="@+id/cell_21" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_22" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_23" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_24" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_25" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_26" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_27" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">
            <TextView android:id="@+id/cell_28" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_29" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_30" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_31" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_32" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_33" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_34" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/cell_35" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_36" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_37" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_38" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_39" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_40" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
            <TextView android:id="@+id/cell_41" android:gravity="center" android:textSize="9sp" android:layout_width="0dp" android:layout_height="20dp" android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
